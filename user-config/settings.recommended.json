{
  "$comment": "MERGE these keys into your existing ~/.claude/settings.json. Do NOT replace the file — you already have config there. bootstrap.sh links the referenced scripts into ~/.claude/{hooks,skills,agents,commands}; apply this by hand or with jq.",

  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },

  "permissions": {
    "allow": [
      "Bash(node *cap.mjs*)",
      "Bash(node *init-project.mjs*)"
    ]
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [{ "type": "command", "command": "node \"$HOME/.claude/hooks/pre-write.mjs\"" }]
      },
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "node \"$HOME/.claude/hooks/commit-gate.mjs\"" }]
      }
    ],
    "SessionStart": [
      { "hooks": [{ "type": "command", "command": "node \"$HOME/.claude/hooks/orient.mjs\"" }] }
    ],
    "PreCompact": [
      { "hooks": [{ "type": "command", "command": "node \"$HOME/.claude/hooks/flush.mjs\"" }] }
    ]
  }
}
